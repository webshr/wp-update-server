# Public base URL used to generate metadata and download links.
WP_UPDATE_SERVER_BASE_URL=https://updates.example.com/

# Writable private storage root for packages, cache, and logs.
WP_UPDATE_SERVER_STORAGE_DIR=storage

# Enable signed download URLs. Use 1 in production for private or paid packages.
WP_UPDATE_SERVER_SIGN_DOWNLOADS=1

# Secret used for HMAC download signatures.
# Generate a long random value and keep it out of version control.
WP_UPDATE_SERVER_SECRET=change-me-to-a-long-random-secret

# GitHub token for private repository release metadata and asset downloads.
# Used automatically by GitHub release package sources when set.
GITHUB_TOKEN=github_pat_change_me
